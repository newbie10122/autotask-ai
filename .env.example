APP_ENV=production
APP_PUBLIC_BASE_URL=https://autotask-ai.example.internal
APP_SESSION_SECRET=change-me-generate-a-long-random-value
APP_SESSION_TTL_SECONDS=28800
APP_ROUTE_AUTH_REQUIRED=false
AUTH_LOGIN_FAILURE_LIMIT=5
AUTH_LOGIN_FAILURE_WINDOW_SECONDS=300

WEB_BIND_HOST=127.0.0.1
WEB_PORT=3010
API_BIND_HOST=127.0.0.1
API_PORT=5110

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=autotask_ai
POSTGRES_USER=autotask_ai
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://autotask_ai:change-me@postgres:5432/autotask_ai
REDIS_URL=redis://redis:6379/0

AUTOTASK_BASE_URL=https://webservices.autotask.net/atservicesrest
AUTOTASK_USERNAME=api-user@example.com
AUTOTASK_SECRET=change-me
AUTOTASK_INTEGRATION_CODE=change-me
AUTOTASK_API_INTEGRATION_CODE=change-me
AUTOTASK_PAGE_SIZE=500
AUTOTASK_SYNC_BATCH_LIMIT=500

OLLAMA_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_MODEL_NAME=nomic-embed-text
EMBEDDING_BATCH_SIZE=16
EMBED_NOISE_CHUNKS=false
ANSWER_TARGET_SECONDS=20
ASSISTANT_NORMAL_TIMEOUT_SECONDS=90
ASSISTANT_MAX_CONTEXT_CHUNKS=8
ASSISTANT_MAX_UNIQUE_TICKETS=5
ASSISTANT_MAX_CHUNKS_PER_TICKET=2
ASSISTANT_EXCLUDE_NOISE_BY_DEFAULT=true
DEEP_DIVE_TIMEOUT_SECONDS=120
OPERATIONS_STATUS_CACHE_TTL_SECONDS=30
TICKET_HEALTH_SUMMARY_CACHE_TTL_SECONDS=60
CUSTOMER_SUCCESS_SUMMARY_CACHE_TTL_SECONDS=60

SYNC_RECENT_INTERVAL_MINUTES=15
NIGHTLY_KNOWLEDGE_CRON='0 2 * * *'
