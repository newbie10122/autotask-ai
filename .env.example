APP_ENV=production
APP_PUBLIC_BASE_URL=https://autotask-ai.example.internal
APP_SESSION_SECRET=change-me-generate-a-long-random-value

WEB_BIND_HOST=127.0.0.1
WEB_PORT=3010
API_BIND_HOST=127.0.0.1
API_PORT=5110

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=autotask_ai
POSTGRES_USER=autotask_ai
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://autotask_ai:change-me@postgres:5432/autotask_ai

AUTOTASK_BASE_URL=https://webservices.autotask.net/atservicesrest
AUTOTASK_USERNAME=api-user@example.com
AUTOTASK_SECRET=change-me
AUTOTASK_API_INTEGRATION_CODE=change-me
AUTOTASK_PAGE_SIZE=500
AUTOTASK_SYNC_BATCH_LIMIT=500

LOCAL_LLM_BASE_URL=http://local-llm:8080
LOCAL_LLM_MODEL_PATH=/models
EMBEDDING_MODEL_NAME=local-cpu-embedding-placeholder
ANSWER_TARGET_SECONDS=20
DEEP_DIVE_TIMEOUT_SECONDS=120

SYNC_RECENT_INTERVAL_MINUTES=15
NIGHTLY_KNOWLEDGE_CRON=0 2 * * *

